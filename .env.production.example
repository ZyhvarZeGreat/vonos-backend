# Vonos — PRODUCTION environment reference
# Set these in Railway (API) and Vercel (web). Do NOT commit real values.

# ── Web (Vercel — production branch `main`) ──
NEXT_PUBLIC_API_URL=https://vonos-api-production.up.railway.app
NEXT_PUBLIC_SKIP_AUTH=false

# ── API (Railway — Production environment, branch `main`) ──
DATABASE_URL=postgresql://USER:PASS@ep-xxx-prod-pooler.region.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=generate-with-openssl-rand-base64-32-prod-only
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d
WEB_ORIGIN=https://app.vonosautos.com,https://app.vonosautosmarket.com
NODE_ENV=production
PORT=3001
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=production-upstash-token
# Without Redis, report/P&L caches are in-memory only and miss across instances.
