# Vonos — STAGING / BETA environment reference
# Set these in Railway (API) and Vercel (web). Do NOT commit real values.

# ── Web (Vercel — staging project or branch `staging`) ──
NEXT_PUBLIC_API_URL=https://vonos-api-staging.up.railway.app
NEXT_PUBLIC_SKIP_AUTH=false

# ── API (Railway — Staging environment, branch `staging`) ──
DATABASE_URL=postgresql://USER:PASS@ep-xxx-staging-pooler.region.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=generate-with-openssl-rand-base64-32-staging-only
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
WEB_ORIGIN=https://vonos-web-staging.vercel.app
NODE_ENV=production
PORT=3001
